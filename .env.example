# Smart Butler server environment variables
# Copy to .env.local for local use (never commit .env.local).

# Required: model key
DASHSCOPE_API_KEY=your_api_key_here

# Optional
SMART_BUTLER_ENV=dev
SMART_BUTLER_MODEL=qwen-turbo
SMART_BUTLER_ALLOW_ORIGINS=*

# Optional: switch from SQLite to PostgreSQL in cloud.
# Render often provides DATABASE_URL or a postgres:// URL.
# This app auto-converts postgres:// to postgresql+psycopg://.
# Example:
# SMART_BUTLER_DB_URL=postgresql+psycopg://user:password@host:5432/dbname
# DATABASE_URL=postgresql://user:password@host:5432/dbname
SMART_BUTLER_DB_URL=sqlite:///./chat_history.db
